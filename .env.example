IRAB_RABYTE_OPENAI_BASE_URL=
IRAB_RABYTE_API_KEY=

# PaiPai research search and China market data.
IRAB_PAIPAI_BASE_URL=
IRAB_PAIPAI_API_KEY=
IRAB_PAIPAI_APP_AGENT=
IRAB_PAIPAI_SIGN=
IRAB_PAIPAI_USER_ID=irab-agent

# Structured market data.
IRAB_GLOBAL_DATA_BASE_URL=

# Public web search.
IRAB_WEBSEARCH_SERVICE_URL=

# Web reader.
IRAB_XIAOSU_READER_URL=
IRAB_XIAOSU_READER_OVERSEAS_URL=
IRAB_XIAOSU_READER_ACCESS_KEY=
IRAB_JINA_READER_BASE_URL=
IRAB_JINA_READER_API_KEY=
